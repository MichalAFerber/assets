_site/
.jekyll-cache/
.jekyll-metadata
.sass-cache/
Gemfile.lock
vendor/
node_modules/

# The global gitignore's macOS "Icon?" rule (for Icon\r resource files) also
# matches this repo's Icons/ asset directory. Re-include it here.
!Icons/
!Icons/**

# Staging area for unsorted assets — drop files here, then ask Claude to
# organize + dedupe them into the vault. Contents are ignored; the folder's
# README is tracked so the folder persists. See CLAUDE.md.
/_Inbox/*
!/_Inbox/README.md
